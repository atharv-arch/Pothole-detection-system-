# ═══════════════════════════════════════════════════════════
# APIS v5.0 — Environment Variables Template
# Copy to .env and fill in your credentials
# ═══════════════════════════════════════════════════════════

# Database
DATABASE_URL=postgresql+asyncpg://apis:password@localhost:5432/apis_db
SYNC_DATABASE_URL=postgresql://apis:password@localhost:5432/apis_db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Copernicus (ESA Sentinel Hub)
COPERNICUS_USER=your_copernicus_username
COPERNICUS_PASS=your_copernicus_password

# AWS S3
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
S3_BUCKET=apis-pothole-data
AWS_REGION=ap-south-1

# Google Gemini AI
GEMINI_API_KEY=

# Twilio (WhatsApp + SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_SMS_FROM=

# CPGRAMS API (Official Grievance Portal API)
CPGRAMS_API_BASE_URL=https://api.cpgrams.gov.in
CPGRAMS_CLIENT_ID=
CPGRAMS_CLIENT_SECRET=

# Data Sovereignty
DATA_RESIDENCY_ZONE=nic-sdc-raipur
CCTV_DATA_CLASSIFICATION=restricted

# NHAI ATMS
NHAI_ATMS_API_KEY=

# System Identity
SYSTEM_EMAIL=apis@chips.cg.gov.in
SYSTEM_EMAIL_PASS=
SYSTEM_PHONE=

# Mapbox (Dashboard)
VITE_MAPBOX_TOKEN=

# App
APP_NAME=APIS
APP_VERSION=5.0.0
DEBUG=false
